alert http any any -> $HOME_NET any (msg:"D-Link DCS-935L suspicious oversized AdminPassword in SetDeviceSettings"; flow:to_server,established; http.uri; content:"/web/cgi-bin/hnap/hnap_service"; nocase; http.header; content:"SetDeviceSettings"; nocase; http.request_body; pcre:"/<AdminPassword>.{256,}<\/AdminPassword>/smi"; classtype:web-application-attack; sid:1001023; rev:2;)
alert http any any -> $HOME_NET any (msg:"D-Link HNAP possible overflow exploit payload"; flow:to_server,established; http.uri; content:"/web/cgi-bin/hnap/hnap_service"; nocase; http.request_body; pcre:"/(A{128,}|BBBBBBBB)/i"; classtype:web-application-attack; sid:1001024; rev:2;)
alert http any any -> $HOME_NET any (msg:"D-Link DCS-935L HNAP SetDeviceSettings MIPS shellcode hex payload in AdminPassword"; flow:to_server,established; http.uri; content:"/web/cgi-bin/hnap/hnap_service"; nocase; http.header; content:"SetDeviceSettings"; nocase; http.request_body; content:"<AdminPassword>"; nocase; pcre:"/<AdminPassword>[0-9A-Fa-f]*27bdffe0[0-9A-Fa-f]*0320f809[0-9A-Fa-f]*<\/AdminPassword>/smi"; classtype:shellcode-detect; sid:1001025; rev:1;)

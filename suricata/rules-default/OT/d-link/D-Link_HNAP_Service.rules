alert http any any -> $HOME_NET any (msg:"D-Link DCS-935L suspicious oversized AdminPassword"; flow:to_server,established; http.uri; content:"/web/cgi-bin/hnap/hnap_service"; nocase; http.request_body; pcre:"/<AdminPassword>.{256,}<\/AdminPassword>/smi"; classtype:web-application-attack; sid:1001023; rev:1;)
alert http any any -> $HOME_NET any (msg:"D-Link HNAP possible overflow exploit payload"; flow:to_server,established; http.uri; content:"/hnap_service"; nocase; http.request_body; pcre:"/(A{128,}|\\x90\\x90|%x%x|ROP|BBBBBBBB)/Ui"; classtype:web-application-attack; sid:1001024; rev:1;)
